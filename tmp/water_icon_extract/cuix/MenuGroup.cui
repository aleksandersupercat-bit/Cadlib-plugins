    <MenuMacro UID="PIPE_PIPEELEMENT">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_220_00612">Добавить элемент</Name>
        <Command>^C^C_pipe_pipeelement</Command>
        <HelpString xlate="true" UID="XLS_220_B6894">Добавить элемент трубопровода. Элемент трубопровода - это деталь или оборудование, размещаемое на трубопровод без разрыва трубы. Элементами трубопровода являются таблички, наварные детали, бобышки, отверстия, датчики и др.</HelpString>
        <SmallImage Name="MStudioInlineAdd.png" />
        <LargeImage Name="MS_PIPE_ELEMENT.png" />
      </Macro>

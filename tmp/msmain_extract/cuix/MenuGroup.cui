        <Command>^C^C_DG_SETHOLE</Command>
        <HelpString xlate="true" UID="XLS_190_64C4D">Выполняет вставку выреза на проекцию</HelpString>
        <SmallImage Name="MStudioDgSetHole16.png" />
        <LargeImage Name="MS_2DSECTION_CUT.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="DG_SHOWHOLE">

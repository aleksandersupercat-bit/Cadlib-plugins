        <Command>^C^C_CLP_PROJECT_STRUCTURE_EDIT</Command>
        <HelpString xlate="true" UID="XLS_200_8AF66">CADLib Проект. Позволяет задать и сохранить в базу данных проекта структуру модели</HelpString>
        <SmallImage Name="CLPModelHierarchyEdit16.png" />
        <LargeImage Name="MS_CLPRP32.png" />

        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_1736">Создать параметрический объект</Name>
        <Command>^C^C_CreateParamEquipment</Command>
        <HelpString xlate="true" UID="XLS_1737">Позволяет создать новое параметрическое оборудование</HelpString>
        <SmallImage Name="MStudioParamEqCreate.png" />
        <LargeImage Name="MS_OBJP_CREATE.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="EditParamEquipment">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_1738">Редактировать параметрический объект</Name>

    <MenuMacro UID="transfer_params_from_block_diagram_to_hierarchy">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="21" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_230_F85EE">CLP. Транслировать параметры ЭС из 2D схемы в 3D</Name>

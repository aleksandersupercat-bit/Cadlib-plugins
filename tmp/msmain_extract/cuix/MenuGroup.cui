        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_1925">Вставить проекцию</Name>
        <Command>^C^C_dg_vport</Command>
        <HelpString xlate="true" UID="XLS_1926">Выполняет вставку проекции с возможностью задать плоскость и параметры отрисовки, обработки данных и надписывания</HelpString>
        <SmallImage Name="MStudioSectionInsert.png" />
        <LargeImage Name="MS_2DSECTION.png" />
      </Macro>
    </MenuMacro>

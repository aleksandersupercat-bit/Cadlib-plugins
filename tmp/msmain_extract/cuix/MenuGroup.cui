    <MenuMacro UID="CLP_UPDATE_OBJECTS">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_00090155">CLP. Проверить актуальность модели</Name>
        <Command>^C^C_CLP_UPDATE_OBJECTS</Command>
        <HelpString xlate="true" UID="XLS_00090156">CADLib Проект. Выполняет проверку актуальности ссылочных элементов модели. При нахождении производятся обновления, а устаревшие попадают на специальный слой (см. настройки)</HelpString>
        <SmallImage Name="CLPUpdateObjects16.png" />
        <LargeImage Name="MS_CLPUPD32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="CLP_REMOVE_DUMMIES">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_200_A080E">CLP.Удалить объекты проекта</Name>
        <Command>^C^C_CLP_REMOVE_DUMMIES</Command>
        <HelpString xlate="true" UID="XLS_200_E0C5B">Удалить объекты проекта из текущего чертежа</HelpString>
        <SmallImage Name="CLPRemoveDummies16.png" />
        <LargeImage Name="MS_CLPCLNDUM32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="CLP_CLEAN_DOCUMENT">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="21" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_200_F67E2">CLP. Удалить связи с проектом</Name>
        <Command>^C^C_CLP_CLEAN_DOCUMENT</Command>
        <HelpString xlate="true" UID="XLS_200_5140A">Удалить связи объектов в текущем чертеже с проектом</HelpString>
        <SmallImage Name="CLPCleanDocument16.png" />
        <LargeImage Name="MS_CLPCLNDOC32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="CLP_LOAD_BY_POLY">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_190_27828">CLP. Загрузить объекты по полилинии</Name>
        <Command>^C^C_CLP_LOAD_BY_POLY</Command>
        <HelpString xlate="true" UID="XLS_190_CAB13">CADLib Проект. Выполняет загрузку объектов модели из базы данных по выбираемой полилинии. Рекомендуется для просмотра пересечений</HelpString>
        <SmallImage Name="CLPLoadByPoly16.png" />
        <LargeImage Name="MS_CLPLOADBYPOLY32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="CLP_LOAD_BY_AXIS_OBJ">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_190_B1E8B">CLP. Загрузить по объектам с осью</Name>
        <Command>^C^C_CLP_LOAD_BY_AXIS_OBJ</Command>
        <HelpString xlate="true" UID="XLS_190_556E8">CADLib Проект. Выполняет загрузку объектов модели из базы данных по выбираемым объектам с осью. Рекомендуется для просмотра пересечений</HelpString>
        <SmallImage Name="CLPLoadByAxisObj16.png" />
        <LargeImage Name="MS_CLPLOADBYAXISOBJ32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="CLP_SHOW_HIERARCHY_QUERY_FORM">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_200_8A8B2">CLP. Загрузить объекты по структуре</Name>
        <Command>^C^C_CLP_SHOW_HIERARCHY_QUERY_FORM</Command>
        <HelpString xlate="true" UID="XLS_200_66A24">CADLib Проект. Выполняет загрузку объектов модели из базы данных проекта путем перекрестного выбора здания/сооружения и структуры модели</HelpString>
        <SmallImage Name="CLPShowHierarchyQueryForm16.png" />
        <LargeImage Name="MS_CLPLOADBYSTRUCT32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="CLP_LOAD_PUBLICATION_OBJECTS">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_220_817D8">CLP. Загрузить публикацию по объектам проекта</Name>
        <Command>^C^C_CLP_LOAD_PUBLICATION_OBJECTS</Command>
        <HelpString xlate="true" UID="XLS_220_07C15">CADLib Проект. Выполняет загрузку из базы данных всех объектов проекта, входящих в публикации, определяемых по выбираемым объектам проекта. Рекомендуется для просмотра связанных объектов</HelpString>
        <SmallImage Name="CLPLoadPublicationDummiesbyDummies16.png" />
        <LargeImage Name="MS_CLPLOADBYDUM32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="CLP_FRAME_CREATE">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_200_920A7">CLP. Создать рамку листа</Name>
        <Command>^C^C_CLP_FRAME_CREATE</Command>
        <HelpString xlate="true" UID="XLS_200_E63E9">CADLib Проект. Позволяет задать рамку границ листа документа для сохранения в базу данных проекта. Рамка границ листа не ассоциирвана с проектом и требует установления связи отдельной командой</HelpString>
        <SmallImage Name="CLPFrameCreate.png" />
        <LargeImage Name="MS_CLPFRAMECREATE32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="CLP_FRAME_DEST_DOCUMENT">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_200_9FA1F">CLP. Ассоциировать лист с проектом</Name>
        <Command>^C^C_CLP_FRAME_DEST_DOCUMENT</Command>
        <HelpString xlate="true" UID="XLS_200_A95E8">CADLib Проект. Позволяет ассоциировать рамку границ листа документа с карточкой документа в проекте</HelpString>
        <SmallImage Name="CLPFrameDestDocument.png" />
        <LargeImage Name="MS_CLPFRAMESTRUCT32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="MSS_SETUP_SURFACE">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_00089991">Ссылка на модель изысканий и проектного рельефа</Name>
        <Command>^C^C_MSS_SETUP_SURFACE</Command>
        <HelpString xlate="true" UID="XLS_00089992">Команда открывает диалог настроек, где можно задать ссылку на источник данных по геодезическим поверхностям, геологическим поверхностям и поверхности проектного рельефа.</HelpString>
        <SmallImage Name="MStudioMSSSetupSurface16.png" />
        <LargeImage Name="MS_GRND_SETTINGS32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="MSS_SET_GROUND_LEVEL ">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_00090101">Сохранить отметку уровня</Name>
        <Command>^C^C_MSS_SET_GROUND_LEVEL </Command>
        <HelpString xlate="true" UID="XLS_00090102">Команда копирует в параметры объекта текущую отметку уровня земли в ключевых точках объекта. Перед запуском команды требуется задать источник данных о земле (см. текущие переменные)</HelpString>
        <SmallImage Name="MStudioMssSetGroundLevel16.png" />
        <LargeImage Name="MS_GRND_OBJLVL.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="urs_properties">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_0015">Параметры объекта</Name>
        <Command>^C^C_urs_properties</Command>
        <HelpString xlate="true" UID="XLS_1774">Команда вызывает диалоговое окно параметров оборудования. В этом диалоговом окне можно редактировать любые параметры объекта, используемые при составлении спецификаций, экспликаций, аксонометрических схем, расчетах и других документов</HelpString>
        <SmallImage Name="MStudioEquipParam.png" />
        <LargeImage Name="MS_PARAM32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="urs_properties_ex">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_191_27BEC">Параметры объекта во внешней ссылке</Name>
        <Command>^C^C_urs_properties_ex</Command>
        <HelpString xlate="true" UID="XLS_191_D96D6">Вызывается диалоговое окно параметров объекта, загруженного через внешнюю ссылку</HelpString>
        <SmallImage Name="_urs_properties_ex 16x16.png" />
        <LargeImage Name="MS_PARAM32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="urs_select">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_1911">Выбрать объекты</Name>
        <Command>^C^C_urs_select</Command>
        <HelpString xlate="true" UID="XLS_1912">Выбрать объекты, удовлетворяющие условию</HelpString>
        <SmallImage Name="MStudioSearchDrawing.png" />
        <LargeImage Name="MS_OBJ_SEARCH.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="URS_PROCESS_MODEL">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_00089985">Обработка модели</Name>
        <Command>^C^C_URS_PROCESS_MODEL</Command>
        <HelpString xlate="true" UID="XLS_00089986">Команда позволяет создавать, редактировать и запускать правила обработки модели. Обработка модели позволяет решать множество задач - обновление значений параметров по заданным условиям, обновление данных из БД и многое другое. Команда предназначена для продвинутых пользователей и не рекомендуется к применению начинающими пользователями</HelpString>
        <SmallImage Name="MStudioURSProcessModel16.png" />
        <LargeImage Name="MS_OBJ_ENGINE.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="Lcs_Lib_Params_Painter">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_00090032">Копировать параметры объектов</Name>
        <Command>^C^C_Lcs_Lib_Params_Painter</Command>
        <HelpString xlate="true" UID="XLS_00090033">Команда позволяет скопировать атрибутивные параметры объектов. Рекомендуется копировать параметры только для однотипных объектов, иначе возможно неверное представление параметризованной графики</HelpString>
        <SmallImage Name="MStudioLcsLibParamsPainter16.png" />
        <LargeImage Name="MS_COPY_PARAMS32.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="PE_ASSOCIATE">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_200_394CD">Ассоциировать объекты</Name>
        <Command>^C^C_PE_ASSOCIATE</Command>
        <HelpString xlate="true" UID="XLS_200_3B07A">Команда позволяет создать ассоциативную связь между объектами модели. Ассоциативная связь устанавливает зависимость положения в пространстве "дочерних" объектов от "родительского"</HelpString>
        <SmallImage Name="MStudioPEAssocCreate.png" />
        <LargeImage Name="MS_ASSOC_OBJ.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="PE_ASSOCIATION_LINKDATA">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="22" MinorVersion="0" UserVersion="1" />
        <Name xlate="true" UID="XLS_200_C390B">Ассоциировать параметры</Name>
        <Command>^C^C_PE_ASSOCIATION_LINKDATA</Command>
        <HelpString xlate="true" UID="XLS_200_DC9A8">Команда позволяет создать ассоциативную связь параметров между ассоциированными объектами модели. Ассоциативная связь параметров устанавливает зависимость значений "дочерних" объектов от "родительского" - связь определяется формулой, т.е. значение может быть вычисляемым!</HelpString>
        <SmallImage Name="AECReinfAssocDataLink.png" />
        <LargeImage Name="MS_ASSOC_PARAMS.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="PE_ASSOCIATION_BREAK">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_200_797E1">Удалить ассоциированность</Name>
        <Command>^C^C_PE_ASSOCIATION_BREAK </Command>
        <HelpString xlate="true" UID="XLS_200_211CF">Команда удаляет ассоциативную связь между объектами модели</HelpString>
        <SmallImage Name="MStudioPEAssocBreak.png" />
        <LargeImage Name="MS_ASSOC_BREAK.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="MSS_CALC_AREA">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_00089978">Расчет объема и площади объекта</Name>
        <Command>^C^C_MSS_CALC_AREA</Command>
        <HelpString xlate="true" UID="XLS_00089979">Команда производит подсчет объема и площади поверхности объектов Model Studio CS. Внимание! Площадь рассчитывается как полная сумма площадей, т.е. внутренние поверхности тоже учитываются</HelpString>
        <SmallImage Name="MStudioCalcVolumeArea16.png" />
        <LargeImage Name="MS_OBJ_VOL_SURF.png" />
      </Macro>
    </MenuMacro>
    <MenuMacro UID="MSWORK_CLEAN">
      <Macro type="Any">
        <Revision MajorVersion="16" MinorVersion="2" UserVersion="1" />
        <ModifiedRev MajorVersion="20" MinorVersion="1" UserVersion="1" />
        <Name xlate="true" UID="XLS_00090019">Удаление объемов работ</Name>
        <Command>^C^C_MSWORK_CLEAN</Command>
        <HelpString xlate="true" UID="XLS_00090020">Команда позволяет удалить одну или несколько работ, присвоенных объекту</HelpString>
        <SmallImage Name="MStudioMSWorkClean16.png" />
        <LargeImage Name="MS_OBJ_DELPARAMS32.png" />
      </Macro>
    </MenuMacro>

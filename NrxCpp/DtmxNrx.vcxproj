<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Set NCadSDK before Default.props so rxsdk props can use it -->
  <PropertyGroup Label="NCadSDK">
    <NCadSDK>c:\pdf_ingest\DTMXtest\NC_SDK_RU_24.1</NCadSDK>
  </PropertyGroup>

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Release NCAD|x64">
      <Configuration>Release NCAD</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{B7E2A1F0-3C5D-4E8A-9B6F-1D2E3A4C5B7D}</ProjectGuid>
    <RootNamespace>DtmxNrx</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release NCAD|x64'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <WholeProgramOptimization>false</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <!-- Import nanoCAD SDK props (sets include paths, lib paths, .nrx extension) -->
  <ImportGroup Condition="'$(Configuration)|$(Platform)'=='Release NCAD|x64'" Label="PropertySheets">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props"
            Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')"
            Label="LocalAppDataPlatform" />
    <Import Project="$(NCadSDK)\include\arxgate\rxsdk_releasecfg.props" />
  </ImportGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release NCAD|x64'">
    <OutDir>c:\pdf_ingest\DTMXtest\Scripts\</OutDir>
    <IntDir>$(SolutionDir)obj\DtmxNrx\</IntDir>
    <TargetName>DtmxNrx45</TargetName>
  </PropertyGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release NCAD|x64'">
    <ClCompile>
      <PrecompiledHeader>Use</PrecompiledHeader>
      <PrecompiledHeaderFile>stdafx.h</PrecompiledHeaderFile>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>Disabled</Optimization>
      <PreprocessorDefinitions>
        DTMXNRX_MODULE;_WIN64;WIN64;WIN32;NDEBUG;_WINDOWS;_USRDLL;_MCS_CORE_ONLY;%(PreprocessorDefinitions)
      </PreprocessorDefinitions>
      <TreatWarningAsError>false</TreatWarningAsError>
      <!-- /utf-8: исходник UTF-8, строковые литералы UTF-8/UTF-16 корректны -->
      <!-- /wd4828: подавить C4828 "invalid UTF-8" в SDK заголовках (Windows-1251) -->
      <AdditionalOptions>/utf-8 /wd4828 %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <TargetMachine>MachineX64</TargetMachine>
      <OutputFile>$(OutDir)$(TargetName).nrx</OutputFile>
      <AdditionalDependencies>McTyp.lib;MechCtl.lib;MT.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="stdafx.cpp">
      <PrecompiledHeader>Create</PrecompiledHeader>
    </ClCompile>
    <ClCompile Include="DtmxNrx.cpp" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

</Project>
